{
  "name": "quickopen-cli",
  "version": "1.0.0",
  "description": "⚡ Open any file by typing its name. Smart, fast, cross-platform CLI tool - 270K+ files in <100ms",
  "type": "commonjs",
  "preferGlobal": true,
  "bin": {
    "qopen": "./bin/open.js"
  },
  "scripts": {
    "start": "node bin/open.js",
    "scan": "node bin/open.js scan",
    "rescan": "node bin/open.js rescan",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "cli",
    "command-line",
    "file-opener",
    "file-search",
    "fuzzy-search",
    "productivity",
    "terminal",
    "cross-platform",
    "developer-tools"
  ],
  "author": {
    "name": "Hardik Gayner",
    "email": "hardikgayner1606@gmail.com",
    "url": "https://github.com/imHardik1606"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imHardik1606/QuickOpen.git"
  },
  "bugs": {
    "url": "https://github.com/imHardik1606/QuickOpen/issues"
  },
  "homepage": "https://github.com/imHardik1606/QuickOpen#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "fast-glob": "^3.3.1",
    "fuse.js": "^7.0.0",
    "inquirer": "^8.2.5"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/imHardik1606"
  }
}
