{
  "name": "QuickOpen",
  "version": "1.0.0",
  "description": "⚡ Open any file by typing its name. Smart, fast, cross-platform CLI tool - 270K+ files in <100ms",
  "main": "bin/open.js",
  "type": "commonjs",
  "bin": {
    "open": "./bin/open.js",
    "quickopen": "./bin/open.js"
  },
  "scripts": {
    "start": "node bin/open.js",
    "scan": "node bin/open.js scan",
    "rescan": "node bin/open.js rescan",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "cli",
    "command-line",
    "file-opener",
    "file-search",
    "fuzzy-search",
    "productivity",
    "terminal",
    "cross-platform",
    "dev-tools",
    "developer-tools",
    "unix",
    "linux",
    "windows",
    "macos",
    "open-files",
    "instant-file-access",
    "file-manager",
    "navigation",
    "workflow-optimization",
    "time-saving"
  ],
  "author": {
    "name": "Hardik Gayner",
    "email": "hardikgayner1606@gmail.com",
    "url": "https://github.com/imHardik1606"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imHardik1606/QuickOpen.git",
    "directory": "."
  },
  "bugs": {
    "url": "https://github.com/imHardik1606/QuickOpen/issues",
    "email": "hardikgayner1606@gmail.com"
  },
  "homepage": "https://github.com/imHardik1606/QuickOpen#readme",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "preferGlobal": true,
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "fast-glob": "^3.3.1",
    "fuse.js": "^7.0.0",
    "inquirer": "^8.2.5"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
